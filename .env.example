# ==============================================================================
# Environment Configuration — Perpustakaan UNISSULA Dashboard
# ==============================================================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai:
#   Windows: copy .env.example .env
#   Linux  : cp .env.example .env
# ==============================================================================

# === DATABASE (WAJIB) ===
# Connection string PostgreSQL.
# Untuk PostgreSQL lokal:
#   DATABASE_URL=postgresql://username:password@localhost:5432/perpustakaan_unissula
# Untuk Neon (cloud):
#   DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# === KEAMANAN (WAJIB) ===
# Secret key untuk JWT token authentication.
# Gunakan string random yang panjang & unik (minimal 32 karakter).
JWT_SECRET=

# === SERVER ===
# Port untuk backend API (default: 3001)
PORT=3001

# Environment: 'development' atau 'production'
NODE_ENV=development

# === FRONTEND (OPSIONAL) ===
# Mode data: 'dummy' untuk data demo, 'production' untuk data real dari API
REACT_APP_DATA_MODE=production

# URL backend API untuk koneksi dari frontend
REACT_APP_API_URL=http://localhost:3001

# Interval auto-refresh data dalam milidetik (default: 300000 = 5 menit)
REACT_APP_REFRESH_INTERVAL=300000
